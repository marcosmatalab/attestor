# Attestor — environment configuration template.
# Copy to `.env` and fill in real values. Never commit `.env`.

# --- Application (used from F0) ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Database: PostgreSQL with multi-tenant RLS (used from F8) ---
DATABASE_URL=

# --- C2PA signing (used from F4) ---
# Dev: a self-signed PEM chain (leaf + CA) and the leaf key on disk.
# Production: the key lives in a KMS/HSM (C2PA_SIGNING_KEY_ARN / AWS_REGION).
C2PA_CERT_PATH=
C2PA_PRIVATE_KEY_PATH=
AWS_REGION=
C2PA_SIGNING_KEY_ARN=

# --- RFC3161 trusted timestamping authority (used from F4/F6) ---
RFC3161_TSA_URL=

# --- Cryptographic ledger: Ed25519 signing key (used from F6) ---
LEDGER_SIGNING_KEY_PATH=
